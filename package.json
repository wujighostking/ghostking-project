{
  "name": "ghostking-project",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "dev": "turbo run dev",
    "dev:nest": "turbo run dev --filter=nest",
    "dev:resume": "turbo run dev --filter=resume",
    "dev:vue-three": "turbo run dev --filter=vue-three",
    "build": "turbo run build",
    "build:nest": "turbo run build --filter=nest",
    "build:resume": "turbo run build --filter=resume",
    "build:vue-three": "turbo run build --filter=vue-three",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/node": "^25.6.2",
    "lint-staged": "^17.0.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpx lint-staged",
    "commit-msg": "pnpx commitlint --edit"
  },
  "lint-staged": {
    ".{js,ts,jsx,tsx,vue}": [
      "pnpm lint:fix",
      "pnpm fmt"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
